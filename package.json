{
  "scripts": {
    "build:css": "sass ./src/sass/main.scss ./dist/main.css --watch",
    "build:js": "esbuild ./src/js/bundle.js --bundle --minify --outfile=./dist/bundle.min.js --watch --external:jquery",
    "build": "npm-run-all --parallel build:css build:js"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "npm-run-all": "^4.1.5",
    "sass": "^1.93.2"
  },
  "dependencies": {
    "swiper": "^12.1.3"
  }
}
